---
import Layout from '../layouts/Layout.astro';
import { speakers, currentSpeakers, pastSpeakers } from '../content/speakers';

const current = currentSpeakers();
const past = pastSpeakers();

// Person schema for each speaker. Helps Google Knowledge Graph.
const peopleLd = speakers.map((s) => ({
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': new URL(`/speakers#${s.slug}`, Astro.site).toString(),
  name: s.name,
  jobTitle: s.role,
  description: s.teaser,
  image: new URL(s.image, Astro.site).toString(),
  url: new URL(`/speakers#${s.slug}`, Astro.site).toString(),
  worksFor: { '@id': `${Astro.site}#organization` },
  knowsAbout: s.topics,
}));
---

<Layout
  title="Speakers"
  description="Meet the Nevada operators behind NLAS. Business owners, nonprofit leaders, authors, and working professionals delivering applied leadership training to K-12 schools and colleges across Nevada."
>
  <Fragment slot="head">
    {peopleLd.map((p) => <script type="application/ld+json" set:html={JSON.stringify(p)} />)}
  </Fragment>

  <!-- Hero -->
  <section class="section pb-12 md:pb-16">
    <div class="container-page">
      <div class="eyebrow">Speakers</div>
      <h1 class="mt-5 text-4xl md:text-6xl lg:text-7xl font-display font-black uppercase leading-[0.98] tracking-tight max-w-5xl">
        Not career lecturers. <span class="script normal-case font-normal">Operators.</span>
      </h1>
      <p class="mt-8 text-lg md:text-xl text-[var(--color-ink)]/85 max-w-3xl leading-relaxed">
        Our speakers are business owners, nonprofit leaders, authors, and operators actively working in Nevada communities. Students lean in because the message is authentic. Administrators book us again because the content is responsible, age-appropriate, and solution focused.
      </p>
    </div>
  </section>

  <!-- Current roster -->
  {current.length > 0 && (
    <section class="!pb-0">
      <div class="container-page">
        <div class="orbit-line mb-2"></div>
        <div class="eyebrow mt-10">Current roster</div>
        <h2 class="mt-5 text-3xl md:text-5xl font-display font-bold leading-tight">
          Our <span class="script">current</span> speakers.
        </h2>
      </div>
    </section>
  )}

  {current.map((s, idx) => (
    <section id={s.slug} class="section !py-16 md:!py-24 scroll-mt-24">
      <div class="container-page">
        <div class={`grid md:grid-cols-12 gap-10 md:gap-16 items-start ${idx % 2 === 1 ? 'md:[&>*:first-child]:order-2' : ''}`}>
          <div class="md:col-span-5 lg:col-span-4 reveal">
            <div class="relative mx-auto max-w-[420px] group">
              <div class="portrait ring-1 ring-[var(--color-border-strong)] shadow-[0_24px_60px_rgba(0,0,0,0.45)]">
                <img src={s.image} alt={`${s.name}, ${s.role}`} width="800" height="800" loading="lazy" decoding="async" />
              </div>
              <a href="/contact" class="portrait-satellite" aria-label={`Book a session featuring ${s.name}`}
                 style={s.accent === 'blue' ? 'background: var(--color-brand-blue); color: #fff;' : ''}>→</a>
            </div>
          </div>

          <div class="md:col-span-7 lg:col-span-8 reveal reveal-delay-1">
            <div class="eyebrow">{idx === 0 ? 'Founder' : `Speaker ${String(idx + 1).padStart(2, '0')}`}</div>
            <h2 class="mt-4 text-4xl md:text-5xl lg:text-6xl font-display font-black uppercase leading-[0.98] tracking-tight">{s.title}</h2>
            <p class="mt-4 text-lg text-[var(--color-brand-gold)]">{s.role}</p>

            <div class="mt-8 space-y-5 text-[1.02rem] leading-relaxed text-[var(--color-ink)]/88">
              {s.bio.map((p) => <p>{p}</p>)}
            </div>

            <div class="mt-10">
              <div class="text-xs font-bold uppercase tracking-[0.16em] text-[var(--color-ink-muted)] mb-4">
                {s.slug === 'joey-charafi'
                  ? 'Joseph and the NLAS speakers challenge students on:'
                  : `Through NLAS, ${s.name.split(' ')[0]} speaks to students about:`}
              </div>
              <ul class="grid sm:grid-cols-2 gap-2">
                {s.topics.map((t) => (
                  <li class="flex items-start gap-3 py-2">
                    <span class="shrink-0 mt-2 w-1.5 h-1.5 rounded-full bg-[var(--color-brand-gold)]"></span>
                    <span class="leading-snug">{t}</span>
                  </li>
                ))}
              </ul>
            </div>

            {s.links && s.links.length > 0 && (
              <div class="mt-8 flex flex-wrap gap-3">
                {s.links.map((l) => (
                  <a href={l.href} target="_blank" rel="noopener" class="text-sm text-[var(--color-brand-gold)] hover:text-[var(--color-brand-gold-hi)] transition inline-flex items-center gap-1">{l.label} <span aria-hidden="true">↗</span></a>
                ))}
              </div>
            )}

            <div class="mt-10 flex flex-wrap gap-3">
              <a href={`/contact?speaker=${s.slug}`} class="btn btn-gold">Book {s.name.split(' ')[0]} →</a>
              <a href="/speakers" class="btn btn-ghost">Back to roster</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Past roster (optional, only renders if any) -->
  {past.length > 0 && (
    <section class="section bg-[var(--color-canvas-lifted)]">
      <div class="container-page">
        <div class="eyebrow">Past speakers</div>
        <h2 class="mt-5 text-3xl md:text-5xl font-display font-bold leading-tight">
          Previously on the <span class="script">NLAS stage.</span>
        </h2>

        <div class="mt-12 grid md:grid-cols-3 gap-10 md:gap-8">
          {past.map((s, i) => (
            <article class={`text-center reveal reveal-delay-${(i % 3) + 1}`}>
              <div class="relative mx-auto w-[220px]">
                <div class="portrait ring-1 ring-[var(--color-border)] opacity-90">
                  <img src={s.image} alt={s.name} width="440" height="440" loading="lazy" />
                </div>
              </div>
              <h3 class="mt-6 text-xl font-display font-bold uppercase tracking-tight">{s.name}</h3>
              <p class="mt-2 text-sm text-[var(--color-ink-muted)]">{s.shortRole}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Become a Speaker CTA -->
  <section class="section pt-0">
    <div class="container-page">
      <div class="orbit-line mb-14"></div>
      <div class="stadium relative overflow-hidden bg-gradient-to-br from-[var(--color-brand-blue-lo)] via-[var(--color-canvas-lifted)] to-[var(--color-canvas-deep)] p-10 md:p-16">
        <svg aria-hidden="true" class="absolute inset-0 w-full h-full opacity-10" viewBox="0 0 800 400" preserveAspectRatio="xMidYMid slice">
          <defs>
            <pattern id="bsDiag" width="18" height="18" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
              <line x1="0" y1="0" x2="0" y2="18" stroke="#E8B547" stroke-width="1.5"/>
            </pattern>
          </defs>
          <rect width="800" height="400" fill="url(#bsDiag)"/>
        </svg>

        <div class="relative grid md:grid-cols-12 gap-8 items-center">
          <div class="md:col-span-7">
            <div class="eyebrow">Become a speaker</div>
            <h2 class="mt-4 text-3xl md:text-5xl font-display font-bold leading-tight">
              Think you've got a <span class="script">story</span> Nevada students need to hear?
            </h2>
            <p class="mt-6 text-[var(--color-ink)]/85 max-w-2xl">
              NLAS is always looking for Nevada-based operators. Founders, authors, athletes, first responders, tradespeople, and community leaders whose lived experience can shape the next generation. If that sounds like you, we want to talk.
            </p>
          </div>
          <div class="md:col-span-5 flex md:justify-end">
            <a href="/contact?type=become-speaker" class="btn btn-gold btn-lg">Apply to speak →</a>
          </div>
        </div>
      </div>

      <div class="mt-14 text-center">
        <div class="eyebrow justify-center">Ready to book</div>
        <h2 class="mt-5 text-3xl md:text-5xl font-display font-bold">
          Bring a Nevada operator into your <span class="script">classroom.</span>
        </h2>
        <a href="/contact" class="mt-8 btn btn-ghost btn-lg">Book NLAS →</a>
      </div>
    </div>
  </section>
</Layout>
