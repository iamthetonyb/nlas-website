---
import Layout from '../layouts/Layout.astro';
import SpeakerCard from '../components/SpeakerCard.astro';
import VideoHero from '../components/VideoHero.astro';
import { featuredSpeakers } from '../content/speakers';
import { pillars, partners, talks } from '../content/site';

const featured = featuredSpeakers();
const stats = [
  { n: 'K-12', l: 'Middle, high, college' },
  { n: '45-60', l: 'Minute assemblies' },
  { n: '1 day', l: 'Quote turnaround' },
  { n: 'NV', l: 'Built for Nevada schools' },
];

const steps = [
  {
    n: '01',
    t: 'Tell us your dates',
    b: 'Send grade level, audience size, and two or three possible dates. We reply inside one business day.',
  },
  {
    n: '02',
    t: 'We shape the session',
    b: 'Your administrator approves the topic, speaker, and outline. We adjust for your community before anything ships.',
  },
  {
    n: '03',
    t: 'We show up ready',
    b: 'Assembly, Q&A, classroom rotations, or parent night. Clean content, clear expectations, no surprise pitch.',
  },
];
---

<Layout
  title="Nevada Leadership & Accountability Series"
  description="Real Nevada voices in Nevada schools. Leadership, accountability, digital responsibility, cyberbullying prevention, and future-of-work education for middle school, high school, and college audiences."
>
  <section class="hero-section section overflow-hidden">
    <div class="topo" aria-hidden="true"></div>
    <div class="container-page relative">
      <div class="eyebrow reveal">Nevada Leadership &amp; Accountability Series · Est. 2024</div>
      <h1 class="display balance mt-10 max-w-[15ch] reveal reveal-delay-1">
        Real Nevada <span class="script">voices</span> in Nevada schools.
      </h1>

      <div class="hero-foot mt-12 md:mt-16">
        <p class="pretty text-lg md:text-xl leading-relaxed text-[var(--color-ink-muted)] max-w-2xl reveal reveal-delay-2">
          A school-safe speaker series for middle school, high school, and college audiences. Leadership, accountability, and online safety taught by operators who live and build in Nevada.
        </p>
        <div class="hero-cta reveal reveal-delay-3">
          <a href="/contact" class="btn btn-gold btn-lg">Book a session →</a>
          <a href="/speakers" class="btn btn-ghost btn-lg">Meet the speakers</a>
        </div>
      </div>

      <dl class="stats-grid mt-20 md:mt-24 reveal reveal-delay-4">
        {stats.map((s) => (
          <div>
            <dt class="stat-num">{s.n}</dt>
            <dd class="stat-label">{s.l}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="section section-tight pt-0">
    <div class="container-page">
      <div class="prototype-note reveal">
        <div class="eyebrow">The reality</div>
        <p class="pretty">
          Social media influence. Cyberbullying. Digital permanence. Cultural noise. Entrepreneurial opportunity without guidance. Leadership visibility without mentorship.
          <span>NLAS gives students language and habits for the world they are actually growing up in.</span>
        </p>
      </div>
    </div>
  </section>

  <div class="ticker" aria-label="NLAS focus areas">
    <div class="ticker-track">
      {[...['Leadership', 'Accountability', 'Online Safety', 'Stepping Up', 'Digital Footprint', 'Ownership', 'Real Work', 'Nevada Built', 'Leadership', 'Accountability', 'Online Safety', 'Stepping Up', 'Digital Footprint', 'Ownership', 'Real Work', 'Nevada Built']].map((t) => (
        <>
          <span>{t}</span>
          <span class="ticker-dot" aria-hidden="true"></span>
        </>
      ))}
    </div>
  </div>

  <section class="section">
    <div class="container-page">
      <div class="section-head">
        <div class="reveal">
          <div class="eyebrow">What we teach</div>
          <h2 class="mt-5 balance">Four pillars. One <span class="script">standard</span> you hold yourself to.</h2>
        </div>
        <p class="lede pretty reveal reveal-delay-1">
          Every session is built on the same foundation: age-appropriate, district-vetted, and shaped by the school before we arrive.
        </p>
      </div>

      <div class="pillar-grid">
        {pillars.map((p, i) => (
          <article class={`pillar reveal reveal-delay-${(i % 4) + 1}`}>
            <div class="num">{p.num}</div>
            <div>
              <h3>{p.title}</h3>
              <p>{p.body}</p>
              <ul>
                {p.topics.map((t) => <li class="chip">{t}</li>)}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <VideoHero
    youtubeId="XKJizOAZdZY"
    orientation="vertical"
    eyebrow="Watch"
    title="See NLAS in the field."
    subtitle="Nevada operators delivering real, direct conversations to students."
  />

  <section class="section light">
    <div class="container-page">
      <div class="section-head">
        <div class="reveal">
          <div class="eyebrow">Talks &amp; assemblies</div>
          <h2 class="mt-5 balance">See what an <span class="script">NLAS hour</span> actually looks like.</h2>
        </div>
        <p class="lede pretty reveal reveal-delay-1">
          Short, practical formats for assemblies, breakouts, career days, and parent-facing evenings.
        </p>
      </div>

      <div class="talk-preview-grid">
        <a href="/talks" class="reel-frame reveal" aria-label="View NLAS talks and assembly formats">
          <div class="reel-title">{talks[0].title}</div>
          <div class="reel-play-btn" aria-hidden="true">
            <svg width="34" height="34" viewBox="0 0 24 24" fill="currentColor"><path d="M7 5v14l12-7z"></path></svg>
          </div>
          <div class="reel-meta"><span>{talks[0].meta}</span><span>{talks[0].duration}</span></div>
        </a>

        <div class="reel-thumbs reveal reveal-delay-1">
          {talks.slice(1).map((t) => (
            <a class="reel-thumb" href="/talks">
              <div class="thumb" aria-hidden="true"></div>
              <div>
                <div class="info-title">{t.title}</div>
                <div class="info-meta">{t.meta}</div>
              </div>
              <div class="dur">{t.duration}</div>
            </a>
          ))}
          <a href="/talks" class="btn btn-ghost justify-between">See all talks →</a>
        </div>
      </div>
    </div>
  </section>

  <section id="speakers" class="section">
    <div class="container-page">
      <div class="section-head">
        <div class="reveal">
          <div class="eyebrow">Current speakers</div>
          <h2 class="mt-5 balance">Operators, not <span class="script">keynote tourists</span>.</h2>
        </div>
        <p class="lede pretty reveal reveal-delay-1">
          Every NLAS speaker lives and works in Nevada. Students hear from people who are still doing the work.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-14 md:gap-10 lg:gap-16 items-start">
        {featured.map((s, i) => (
          <div class={`reveal reveal-delay-${i + 1}`}>
            <SpeakerCard name={s.name} role={s.shortRole} slug={s.slug} image={s.image} blurb={s.teaser} accent={s.accent} />
          </div>
        ))}
      </div>

      <div class="mt-16 text-center">
        <a href="/speakers" class="btn btn-ghost btn-lg">See full roster →</a>
      </div>
    </div>
  </section>

  <section class="section bg-[var(--color-canvas-lifted)] border-y border-[var(--color-border)]">
    <div class="container-page">
      <div class="section-head">
        <div class="reveal">
          <div class="eyebrow">How it works</div>
          <h2 class="mt-5 balance">Booked in days. <span class="script">Vetted</span> before we arrive.</h2>
        </div>
        <p class="lede pretty reveal reveal-delay-1">
          No pitch deck. No data capture. No surprise content. One conversation, a clean quote, a confirmed date.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        {steps.map((s, i) => (
          <article class={`card reveal reveal-delay-${i + 1}`}>
            <div class="num mb-5">{s.n}</div>
            <h3>{s.t}</h3>
            <p class="pretty mt-4 text-[var(--color-ink-muted)]">{s.b}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-tight">
    <div class="container-page text-center">
      <div class="eyebrow justify-center reveal">Partners &amp; resource organizations</div>
      <div class="partner-cloud mt-8 reveal reveal-delay-1">
        {partners.map((p) => <span class="chip">{p}</span>)}
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container-page">
      <div class="cta-band reveal">
        <div>
          <div class="eyebrow">Bring NLAS to your school</div>
          <h2 class="mt-5 balance">The hour your students still <span class="script">talk about</span> a month later.</h2>
        </div>
        <div class="cta-actions">
          <p class="pretty text-[var(--color-ink-muted)]">
            Send your dates. We confirm fit, send a clean quote, and hold time on the calendar for 72 hours.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/contact" class="btn btn-gold">Request a quote →</a>
            <a href="mailto:hello@leadershipseries.org" class="btn btn-ghost">hello@leadershipseries.org</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
