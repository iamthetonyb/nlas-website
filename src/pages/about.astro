---
import Layout from '../layouts/Layout.astro';
import VideoHero from '../components/VideoHero.astro';
import { beliefs, faqs } from '../content/site';
---

<Layout
  title="About"
  description="NLAS is a Nevada-based initiative equipping middle school, high school, and college students to lead with integrity, discipline, and digital responsibility. Real operators, real conversations."
  schemaType="AboutPage"
>
  <section class="section pb-12 md:pb-16 overflow-hidden">
    <div class="topo" aria-hidden="true"></div>
    <div class="container-page relative">
      <div class="eyebrow reveal">About the series</div>
      <h1 class="display balance mt-10 max-w-[16ch] reveal reveal-delay-1">
        A standard you <span class="script">hold yourself</span> to.
      </h1>
      <div class="mt-12 md:mt-16 grid md:grid-cols-2 gap-10 md:gap-14">
        <p class="pretty text-lg md:text-xl text-[var(--color-ink)]/90 leading-relaxed reveal reveal-delay-2">
          NLAS started with a simple observation. Students hear motivational talks all year long and remember almost none of them. What sticks is the person who showed up, did the work in front of them, and told the truth.
        </p>
        <p class="pretty text-[var(--color-ink-muted)] leading-relaxed reveal reveal-delay-3">
          We built the series around that. Every speaker lives in Nevada. Every session is pre-vetted by the school. Every topic connects to something students face this week: online, in the hallway, on the team, and at home.
        </p>
      </div>
    </div>
  </section>

  <section class="section light">
    <div class="container-page">
      <div class="section-head">
        <div class="reveal">
          <div class="eyebrow">What we believe</div>
          <h2 class="mt-5 balance">Five operating <span class="script">principles</span>.</h2>
        </div>
        <p class="lede pretty reveal reveal-delay-1">
          These are the rules we use when deciding what to say yes to and what to decline.
        </p>
      </div>

      <div class="belief-list">
        {beliefs.map((b, i) => (
          <article class={`belief-row reveal reveal-delay-${(i % 4) + 1}`}>
            <div class="num">{b.n}</div>
            <h3>{b.k}</h3>
            <p>{b.v}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-page">
      <div class="grid md:grid-cols-2 gap-10 md:gap-14 items-center">
        <div class="reveal">
          <div class="eyebrow">Our mission</div>
          <h2 class="mt-5 balance">Develop leaders Nevada will be proud to <span class="script">hand the keys</span> to.</h2>
        </div>
        <div class="grid gap-5 text-[var(--color-ink-muted)] leading-relaxed reveal reveal-delay-1">
          <p class="pretty">We partner with schools across the state to deliver practical leadership training, digital responsibility education, and honest conversations about stepping up in the classroom, in the community, and online.</p>
          <p class="pretty">We partner with trusted resource organizations when a topic needs deeper expertise. That is how we cover harder subjects responsibly and stay inside the lines districts care about.</p>
        </div>
      </div>
    </div>
  </section>

  <VideoHero
    youtubeId="XKJizOAZdZY"
    orientation="vertical"
    eyebrow="Watch"
    title="NLAS in the field."
    subtitle="Nevada operators delivering real, direct conversations to classrooms and colleges."
  />

  <section class="section bg-[var(--color-canvas-lifted)] border-y border-[var(--color-border)]">
    <div class="container-page">
      <div class="section-head">
        <div class="reveal">
          <div class="eyebrow">Administrator FAQ</div>
          <h2 class="mt-5 balance">The questions we hear most.</h2>
        </div>
      </div>

      <div class="faq-list reveal reveal-delay-1">
        {faqs.map((f, i) => (
          <details class="faq-item" open={i === 0}>
            <summary>
              <span class="num">{String(i + 1).padStart(2, '0')}</span>
              <span>{f.q}</span>
              <span class="faq-plus" aria-hidden="true">+</span>
            </summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-page">
      <div class="cta-band reveal">
        <div>
          <div class="eyebrow">Bring NLAS to your school</div>
          <h2 class="mt-5 balance">Ready when your <span class="script">calendar</span> is.</h2>
        </div>
        <div class="cta-actions">
          <p class="pretty text-[var(--color-ink-muted)]">Send the audience, goals, and date range. We reply with fit, format, and next steps.</p>
          <div class="flex flex-wrap gap-3">
            <a href="/contact" class="btn btn-gold">Request a quote →</a>
            <a href="/speakers" class="btn btn-ghost">Meet the speakers</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
