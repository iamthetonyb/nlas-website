---
import Layout from '../layouts/Layout.astro';
import VideoHero from '../components/VideoHero.astro';

const beliefs = [
  {
    t: 'Leadership is responsibility, not status.',
    d: 'Leadership shows up in how you carry pressure, not in a title. We teach students that accountability is a daily practice.',
  },
  {
    t: 'Entrepreneurship is value creation, not fame.',
    d: 'Real businesses solve real problems. We connect students to Nevada founders who have built, hired, and delivered for decades.',
  },
  {
    t: 'Digital platforms are permanent records.',
    d: 'We teach digital responsibility and cyberbullying awareness in plain language, before a post shapes a future.',
  },
];
---

<Layout
  title="About"
  description="NLAS is a Nevada-based initiative equipping K-12 and college students to lead with integrity, discipline, and digital responsibility. Real operators, real conversations."
  schemaType="AboutPage"
>
  <section class="section pb-12 md:pb-16">
    <div class="container-page">
      <div class="eyebrow">About NLAS</div>
      <h1 class="mt-5 text-4xl md:text-6xl lg:text-7xl font-display font-black uppercase leading-[0.98] tracking-tight max-w-5xl">
        Investing in Nevada's next <span class="script normal-case font-normal">generation.</span>
      </h1>
      <p class="mt-8 text-lg md:text-xl text-[var(--color-ink)]/85 max-w-3xl leading-relaxed">
        The Nevada Leadership &amp; Accountability Series exists to equip middle school, high school, and college students with the mindset and skills necessary to lead in today's rapidly evolving world.
      </p>
    </div>
  </section>

  <section class="section !py-16 bg-[var(--color-canvas-lifted)]">
    <div class="container-page grid md:grid-cols-12 gap-10">
      <div class="md:col-span-5">
        <div class="eyebrow">The why</div>
        <h2 class="mt-5 text-3xl md:text-5xl font-display font-bold leading-tight">
          Previous generations didn't <span class="script">face this.</span>
        </h2>
      </div>
      <div class="md:col-span-7">
        <p class="text-lg leading-relaxed text-[var(--color-ink)]/85">
          Social media influence. Cyberbullying. Digital permanence. Cultural noise. Entrepreneurial opportunity without guidance. Leadership visibility without mentorship.
        </p>
        <p class="mt-6 text-base text-[var(--color-ink-muted)] leading-relaxed">
          NLAS brings working Nevada leaders into K-12 schools and colleges for real, direct, practical conversations. Not a motivational speech. Applied leadership training rooted in real world experience.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-page">
      <div class="max-w-3xl">
        <div class="eyebrow">Our mission</div>
        <h2 class="mt-5 text-4xl md:text-6xl font-display font-black leading-[1.02] tracking-tight">
          To strengthen Nevada's future by investing in its <span class="script normal-case font-normal">students today.</span>
        </h2>
      </div>

      <div class="mt-14 grid md:grid-cols-3 gap-5">
        {beliefs.map((b, i) => (
          <article class={`card !rounded-[28px] !p-8 border-[var(--color-border-strong)] reveal reveal-delay-${i + 1}`}>
            <div class="text-sm font-bold text-[var(--color-brand-gold)]">{String(i+1).padStart(2,'0')}</div>
            <h3 class="mt-3 text-xl md:text-2xl font-display font-bold leading-snug">{b.t}</h3>
            <p class="mt-4 text-[var(--color-ink-muted)] leading-relaxed text-[0.98rem]">{b.d}</p>
          </article>
        ))}
      </div>

      <p class="mt-12 text-lg md:text-xl text-[var(--color-ink)]/85 max-w-3xl leading-relaxed">
        And we believe when students understand these truths early, they make better decisions, build stronger futures, and positively impact their communities.
      </p>
    </div>
  </section>

  <!-- Video. NLAS in the field. -->
  <VideoHero
    youtubeId="XKJizOAZdZY"
    orientation="vertical"
    eyebrow="Watch"
    title="NLAS in the field."
    subtitle="Nevada operators delivering real, direct conversations to K-12 classrooms and colleges."
  />

  <section class="section pt-0">
    <div class="container-page">
      <div class="stadium bg-gradient-to-br from-[var(--color-brand-blue-lo)] to-[var(--color-canvas-lifted)] p-10 md:p-14 relative overflow-hidden">
        <div class="relative grid md:grid-cols-2 gap-8 items-center">
          <div>
            <div class="eyebrow">Partner with NLAS</div>
            <h2 class="mt-4 text-3xl md:text-5xl font-display font-bold leading-tight">
              Ready to bring this to your students?
            </h2>
          </div>
          <div class="md:text-right">
            <a href="/contact" class="btn btn-gold btn-lg">Book a session →</a>
            <p class="mt-4 text-sm text-white/70">K-12 · Colleges</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
