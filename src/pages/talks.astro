---
import Layout from '../layouts/Layout.astro';
import { talks } from '../content/site';
---

<Layout
  title="Talks & Assembly Formats"
  description="NLAS talks and assembly formats for Nevada schools: leadership, accountability, digital responsibility, cyberbullying prevention, career pathways, and parent-facing sessions."
>
  <section class="section pb-12 md:pb-16 overflow-hidden">
    <div class="topo" aria-hidden="true"></div>
    <div class="container-page relative">
      <div class="eyebrow reveal">Talks &amp; assemblies</div>
      <h1 class="display balance mt-10 max-w-[14ch] reveal reveal-delay-1">
        The <span class="script">work</span>, built for school time.
      </h1>
      <p class="pretty mt-8 text-lg md:text-xl text-[var(--color-ink-muted)] max-w-3xl leading-relaxed reveal reveal-delay-2">
        NLAS formats are practical, age-aware, and shaped with administrators before event day. Assembly, breakout, career day, parent evening, or full panel.
      </p>
    </div>
  </section>

  <section class="section light">
    <div class="container-page">
      <div class="grid md:grid-cols-2 gap-8">
        {talks.map((t, i) => (
          <article class={`talk-card reveal reveal-delay-${(i % 4) + 1}`}>
            <a href="/contact" class="reel-frame" aria-label={`Book ${t.title}`}>
              <div class="reel-title">{t.title}</div>
              <div class="reel-play-btn" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M7 5v14l12-7z"></path></svg>
              </div>
              <div class="reel-meta"><span>{t.meta}</span><span>{t.duration}</span></div>
            </a>
            <div class="mt-5">
              <div class="num">{String(t.id).padStart(2, '0')}</div>
              <h2 class="mt-3 text-2xl md:text-3xl font-display font-bold">{t.title}</h2>
              <p class="pretty mt-3 text-[#4a5466] leading-relaxed">{t.detail}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-page">
      <div class="cta-band reveal">
        <div>
          <div class="eyebrow">Need a custom format?</div>
          <h2 class="mt-5 balance">Tell us your audience. We shape the <span class="script">session</span>.</h2>
        </div>
        <div class="cta-actions">
          <p class="pretty text-[var(--color-ink-muted)]">
            We can tailor session length, tone, topic mix, Q&amp;A, and parent-facing add-ons around the school calendar.
          </p>
          <a href="/contact" class="btn btn-gold w-fit">Request a quote →</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
