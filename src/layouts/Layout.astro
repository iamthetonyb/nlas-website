---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  type?: 'website' | 'article' | 'profile';
  /** schema.org type override 4 structured data on this page */
  schemaType?: 'Organization' | 'WebSite' | 'AboutPage' | 'ContactPage' | 'Person';
}

const {
  title = 'Nevada Leadership & Accountability Series',
  description = 'Nevada operators teaching K-12 students and college classrooms what accountability, digital responsibility, and honest leadership look like in practice. Not theory. Not a motivational speech.',
  image = '/og-image.png',
  canonical,
  noindex = false,
  type = 'website',
  schemaType = 'WebSite',
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();
const fullTitle = title === 'Nevada Leadership & Accountability Series'
  ? 'Nevada Leadership & Accountability Series · Real Nevada Leaders'
  : `${title} · NLAS`;

// ---------- Structured Data ----------
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${Astro.site}#organization`,
  name: 'Nevada Leadership & Accountability Series',
  alternateName: ['NLAS', 'Nevada Leadership Series'],
  url: Astro.site?.toString(),
  logo: {
    '@type': 'ImageObject',
    url: new URL('/icon-512.png', Astro.site).toString(),
    width: 512,
    height: 512,
  },
  image: ogImage,
  description,
  areaServed: { '@type': 'State', name: 'Nevada' },
  foundingLocation: { '@type': 'Place', name: 'Las Vegas, Nevada, United States' },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Las Vegas',
    addressRegion: 'NV',
    addressCountry: 'US',
  },
  knowsAbout: [
    'Leadership development',
    'Student accountability',
    'Digital responsibility',
    'Cyberbullying prevention',
    'Youth entrepreneurship',
    'Career and technical education',
  ],
  sameAs: [],
};

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${Astro.site}#website`,
  url: Astro.site?.toString(),
  name: 'Nevada Leadership & Accountability Series',
  description,
  publisher: { '@id': `${Astro.site}#organization` },
  inLanguage: 'en-US',
};

const pageLd = schemaType && schemaType !== 'WebSite' && schemaType !== 'Organization' ? {
  '@context': 'https://schema.org',
  '@type': schemaType,
  name: fullTitle,
  description,
  url: canonicalURL,
  isPartOf: { '@id': `${Astro.site}#website` },
} : null;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0A1628" />
    <meta name="color-scheme" content="dark" />
    <meta name="format-detection" content="telephone=no" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Nevada Leadership & Accountability Series" />
    <meta name="publisher" content="Nevada Leadership & Accountability Series" />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Keywords (low SEO weight but some crawlers still use) -->
    <meta name="keywords" content="Nevada leadership, student leadership training, accountability, digital responsibility, cyberbullying prevention, youth entrepreneurship, school assembly speakers, Las Vegas speakers, NLAS, Joseph Charafi, Cody Whipple, Marlon Medina, Stop The Traffic Foundation" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Nevada Leadership & Accountability Series" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Nevada Leadership & Accountability Series. Real Nevada leaders. Real conversations." />

    <!-- Square variant for iMessage / LinkedIn avatar-style previews -->
    <meta property="og:image" content={new URL('/og-square.png', Astro.site).toString()} />
    <meta property="og:image:width" content="1080" />
    <meta property="og:image:height" content="1080" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Nevada Leadership & Accountability Series" />

    <!-- iMessage / Apple (Apple reads og + apple-mobile-web-app tags) -->
    <meta name="apple-mobile-web-app-title" content="NLAS" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <!-- Modern equivalent. Chrome 134+ deprecated apple-mobile-web-app-capable; ship both for now. -->
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="application-name" content="NLAS" />

    <!-- Icons -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/favicon.svg" color="#0A1628" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Performance hints -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.youtube-nocookie.com" />

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;450;500;600;700&family=Archivo:wght@500;600;700;800;900&family=Dancing+Script:wght@500;600;700&display=swap" rel="stylesheet" />

    <!-- Structured Data: Organization + WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    {pageLd && <script type="application/ld+json" set:html={JSON.stringify(pageLd)} />}

    <!-- Astro 5 View Transitions. SPA-style cross-fade navigation, zero framework dependency.
         fallback="animate" = JS-simulated cross-fade for browsers w/o native View Transitions API (Firefox, Safari ≤17). -->
    <ClientRouter fallback="animate" />

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[60] btn btn-gold">Skip to content</a>
    <Navbar />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer />

    <!-- Scroll-reveal observer. Adds .is-visible to .reveal elements entering the viewport.
         Bundled module script (NOT is:inline). Astro 5 deduplicates module scripts across
         ClientRouter swaps, so this registers astro:page-load ONCE — the listener fires on
         initial load AND every SPA navigation. Each fire creates a fresh IO and disconnects
         the prior one on the next before-swap to prevent observer leaks across pages. -->
    <script>
      let activeIO: IntersectionObserver | null = null;
      function initReveal() {
        if (activeIO) { activeIO.disconnect(); activeIO = null; }
        const els = document.querySelectorAll<HTMLElement>('.reveal:not(.is-visible)');
        if (!els.length) return;
        if (!('IntersectionObserver' in window) || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          });
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.08 });
        els.forEach((el) => io.observe(el));
        activeIO = io;
      }
      document.addEventListener('astro:page-load', initReveal);
      // Tear down before the DOM gets swapped — IO holds strong refs to its targets.
      document.addEventListener('astro:before-swap', () => {
        if (activeIO) { activeIO.disconnect(); activeIO = null; }
      });

      // Focus management for SPA navigation. After a ClientRouter swap, browsers
      // do NOT move focus the way they do on a full page load, so keyboard and
      // screen-reader users get stranded on the old element. Move focus to the
      // new main landmark on every nav (but skip the very first page-load so we
      // don't steal focus from the URL bar / autofocus targets on hard refresh).
      let firstLoad = true;
      document.addEventListener('astro:page-load', () => {
        if (firstLoad) { firstLoad = false; return; }
        const main = document.getElementById('main');
        if (main) {
          main.focus({ preventScroll: true });
          // Hint screen readers without speaking the whole landmark.
          window.scrollTo({ top: 0, left: 0, behavior: 'auto' });
        }
      });
    </script>
  </body>
</html>
