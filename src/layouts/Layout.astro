---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}
const {
  title = 'Nevada Leadership & Accountability Series',
  description = 'Preparing the next generation of Nevada students to lead with integrity, discipline, and digital responsibility. Real Nevada leaders, real conversations.',
  image = '/og-image.png',
  canonical,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const fullTitle = title === 'Nevada Leadership & Accountability Series'
  ? title
  : `${title} · NLAS`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0A1628" />
    <meta name="color-scheme" content="dark" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(image, Astro.site).toString()} />
    <meta property="og:site_name" content="NLAS" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).toString()} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;450;500;600;700&family=Archivo:wght@500;600;700;800;900&family=Dancing+Script:wght@500;600;700&display=swap" rel="stylesheet" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Nevada Leadership & Accountability Series',
      alternateName: 'NLAS',
      url: canonicalURL,
      logo: new URL('/favicon.svg', Astro.site).toString(),
      description,
      areaServed: 'Nevada',
      foundingLocation: { '@type': 'Place', name: 'Las Vegas, Nevada' },
      sameAs: [],
    })} />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[60] btn btn-gold">Skip to content</a>
    <Navbar />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
