---
/**
 * VideoHero
 * ----------------------------------------------------------------------
 * Flexible video section for the homepage. Supports 3 modes:
 *   1. Self-hosted MP4 in /public/video/nlas-hero.mp4
 *   2. YouTube embed — pass `youtubeId`
 *   3. Vimeo embed    — pass `vimeoId`
 *
 * Until a real asset is provided, it renders a branded poster frame
 * w/ a large gold play button that links to the contact form — so the
 * section never looks broken while footage is being edited.
 */
interface Props {
  src?: string;            // e.g. "/video/nlas-hero.mp4"
  poster?: string;         // poster still image URL
  youtubeId?: string;      // e.g. "dQw4w9WgXcQ"
  vimeoId?: string;        // e.g. "123456789"
  eyebrow?: string;
  title?: string;
  subtitle?: string;
}
const {
  src,
  poster = '/og-image.png',
  youtubeId,
  vimeoId,
  eyebrow = 'In the field',
  title = "See NLAS in action.",
  subtitle = "Real Nevada leaders, real classrooms, real conversations.",
} = Astro.props;

const hasVideo = Boolean(src || youtubeId || vimeoId);
---

<section id="video" class="section !pt-0">
  <div class="container-page">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">
      <div>
        <div class="eyebrow">{eyebrow}</div>
        <h2 class="mt-5 text-3xl md:text-5xl font-display font-bold leading-tight max-w-2xl">
          {title}
        </h2>
      </div>
      <p class="max-w-md text-[var(--color-ink-muted)]">{subtitle}</p>
    </div>

    <div class="stadium relative aspect-video bg-[var(--color-canvas-lifted)] shadow-[0_24px_60px_rgba(0,0,0,0.45)] ring-1 ring-[var(--color-border)]">
      {youtubeId && (
        <iframe
          class="absolute inset-0 w-full h-full"
          src={`https://www.youtube-nocookie.com/embed/${youtubeId}?rel=0&modestbranding=1&color=white`}
          title="NLAS — video"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      )}

      {vimeoId && (
        <iframe
          class="absolute inset-0 w-full h-full"
          src={`https://player.vimeo.com/video/${vimeoId}?title=0&byline=0&portrait=0`}
          title="NLAS — video"
          loading="lazy"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
        ></iframe>
      )}

      {src && !youtubeId && !vimeoId && (
        <video
          class="absolute inset-0 w-full h-full object-cover"
          src={src}
          poster={poster}
          controls
          playsinline
          preload="metadata"
        ></video>
      )}

      {!hasVideo && (
        <!-- Branded placeholder -->
        <div class="absolute inset-0 overflow-hidden">
          <!-- Ambient gradient wash -->
          <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 20%, rgba(61,120,201,0.35) 0%, transparent 60%), radial-gradient(ellipse at 80% 80%, rgba(232,181,71,0.15) 0%, transparent 55%), linear-gradient(135deg, #0A1628 0%, #1A3E7C 100%);"></div>

          <!-- Diagonal stripe pattern -->
          <svg aria-hidden="true" class="absolute inset-0 w-full h-full opacity-15" viewBox="0 0 1200 675" preserveAspectRatio="xMidYMid slice">
            <defs>
              <pattern id="vidDiag" width="18" height="18" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
                <line x1="0" y1="0" x2="0" y2="18" stroke="#3D78C9" stroke-width="2"/>
              </pattern>
            </defs>
            <rect width="1200" height="675" fill="url(#vidDiag)"/>
          </svg>

          <div class="relative w-full h-full flex flex-col items-center justify-center text-center px-6">
            <!-- Big play button -->
            <button type="button" id="vid-play-placeholder" class="group w-24 h-24 md:w-32 md:h-32 rounded-full bg-[var(--color-brand-gold)] text-[#1A1200] flex items-center justify-center shadow-[0_24px_48px_rgba(0,0,0,0.5)] hover:scale-105 transition-transform" aria-label="Video coming soon">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="translate-x-0.5">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </button>

            <div class="mt-8 eyebrow" style="color: #E8B547;">Coming soon</div>
            <p class="mt-3 text-xl md:text-2xl font-display font-bold text-white max-w-md">
              Feature video launching shortly.
            </p>
            <p class="mt-3 text-sm text-[var(--color-ink-muted)] max-w-sm">
              In the meantime, meet the speakers or request a session for your school.
            </p>
            <div class="mt-8 flex flex-wrap gap-3 justify-center">
              <a href="/speakers" class="btn btn-ghost">Meet the speakers</a>
              <a href="/contact" class="btn btn-gold">Book NLAS →</a>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

{!hasVideo && (
  <script is:inline>
    document.getElementById('vid-play-placeholder')?.addEventListener('click', () => {
      window.location.href = '/contact';
    });
  </script>
)}
