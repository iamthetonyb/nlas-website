---
/**
 * VideoHero — flexible video showcase.
 * Modes:  self-hosted MP4 | YouTube (incl. Shorts) | Vimeo | branded placeholder
 * Orientation: 'landscape' (16:9) or 'vertical' (9:16 centered, great 4 YT Shorts)
 */
interface Props {
  src?: string;
  poster?: string;
  youtubeId?: string;
  vimeoId?: string;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  orientation?: 'landscape' | 'vertical';
}
const {
  src,
  poster = '/og-image.png',
  youtubeId,
  vimeoId,
  eyebrow = 'Watch',
  title = 'See NLAS in the classroom.',
  subtitle = 'Real Nevada leaders. Real audiences. Real conversations.',
  orientation = 'landscape',
} = Astro.props;

const hasVideo = Boolean(src || youtubeId || vimeoId);
const isVertical = orientation === 'vertical';
---

<section id="video" class="section !pt-0">
  <div class="container-page">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">
      <div>
        <div class="eyebrow">{eyebrow}</div>
        <h2 class="mt-5 text-3xl md:text-5xl font-display font-bold leading-tight max-w-2xl">{title}</h2>
      </div>
      <p class="max-w-md text-[var(--color-ink-muted)]">{subtitle}</p>
    </div>

    {isVertical && hasVideo ? (
      <!-- Vertical Short: 2-col on desktop. Phone-sized player left, copy right. -->
      <div class="grid md:grid-cols-12 gap-8 md:gap-12 items-center">
        <div class="md:col-span-5 lg:col-span-4 mx-auto w-full max-w-[360px]">
          <div class="relative aspect-[9/16] stadium bg-black shadow-[0_24px_60px_rgba(0,0,0,0.45)] ring-1 ring-[var(--color-border)]">
            {youtubeId && (
              <iframe
                class="absolute inset-0 w-full h-full"
                src={`https://www.youtube-nocookie.com/embed/${youtubeId}?rel=0&modestbranding=1&playsinline=1`}
                title="NLAS — short"
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              ></iframe>
            )}
            {vimeoId && (
              <iframe
                class="absolute inset-0 w-full h-full"
                src={`https://player.vimeo.com/video/${vimeoId}?title=0&byline=0&portrait=0`}
                title="NLAS — short"
                loading="lazy"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
              ></iframe>
            )}
            {src && !youtubeId && !vimeoId && (
              <video class="absolute inset-0 w-full h-full object-cover" src={src} poster={poster} controls playsinline preload="metadata"></video>
            )}
          </div>
        </div>
        <div class="md:col-span-7 lg:col-span-8">
          <p class="text-lg md:text-xl leading-relaxed text-[var(--color-ink)]/85 max-w-xl">
            A quick look at NLAS in the field — Nevada speakers delivering real, direct conversations to K-12 students and colleges across the state.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/speakers" class="btn btn-ghost">Meet the speakers</a>
            <a href="/contact" class="btn btn-gold">Book NLAS →</a>
          </div>
        </div>
      </div>
    ) : (
      <div class="stadium relative aspect-video bg-[var(--color-canvas-lifted)] shadow-[0_24px_60px_rgba(0,0,0,0.45)] ring-1 ring-[var(--color-border)]">
        {youtubeId && (
          <iframe
            class="absolute inset-0 w-full h-full"
            src={`https://www.youtube-nocookie.com/embed/${youtubeId}?rel=0&modestbranding=1&color=white`}
            title="NLAS — video"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        )}
        {vimeoId && (
          <iframe
            class="absolute inset-0 w-full h-full"
            src={`https://player.vimeo.com/video/${vimeoId}?title=0&byline=0&portrait=0`}
            title="NLAS — video"
            loading="lazy"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          ></iframe>
        )}
        {src && !youtubeId && !vimeoId && (
          <video class="absolute inset-0 w-full h-full object-cover" src={src} poster={poster} controls playsinline preload="metadata"></video>
        )}

        {!hasVideo && (
          <div class="absolute inset-0 overflow-hidden">
            <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 20%, rgba(61,120,201,0.35) 0%, transparent 60%), radial-gradient(ellipse at 80% 80%, rgba(232,181,71,0.15) 0%, transparent 55%), linear-gradient(135deg, #0A1628 0%, #1A3E7C 100%);"></div>
            <svg aria-hidden="true" class="absolute inset-0 w-full h-full opacity-15" viewBox="0 0 1200 675" preserveAspectRatio="xMidYMid slice">
              <defs>
                <pattern id="vidDiag" width="18" height="18" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
                  <line x1="0" y1="0" x2="0" y2="18" stroke="#3D78C9" stroke-width="2"/>
                </pattern>
              </defs>
              <rect width="1200" height="675" fill="url(#vidDiag)"/>
            </svg>
            <div class="relative w-full h-full flex flex-col items-center justify-center text-center px-6">
              <a href="/contact" class="group w-24 h-24 md:w-32 md:h-32 rounded-full bg-[var(--color-brand-gold)] text-[#1A1200] flex items-center justify-center shadow-[0_24px_48px_rgba(0,0,0,0.5)] hover:scale-105 transition-transform" aria-label="Book NLAS">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="translate-x-0.5"><path d="M8 5v14l11-7z"/></svg>
              </a>
              <div class="mt-8 eyebrow" style="color: #E8B547;">Coming soon</div>
              <p class="mt-3 text-xl md:text-2xl font-display font-bold text-white max-w-md">Feature video launching shortly.</p>
              <p class="mt-3 text-sm text-[var(--color-ink-muted)] max-w-sm">In the meantime, meet the speakers or request a session.</p>
              <div class="mt-8 flex flex-wrap gap-3 justify-center">
                <a href="/speakers" class="btn btn-ghost">Meet the speakers</a>
                <a href="/contact" class="btn btn-gold">Book NLAS →</a>
              </div>
            </div>
          </div>
        )}
      </div>
    )}
  </div>
</section>
