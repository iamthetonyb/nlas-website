---
interface Props {
  name: string;
  role: string;
  slug: string;
  image: string;
  blurb: string;
  accent?: 'gold' | 'blue';
}
const { name, role, slug, image, blurb, accent = 'gold' } = Astro.props;
---

<article class="group relative flex flex-col items-center text-center">
  <div class="relative w-[260px] md:w-[300px] lg:w-[320px]">
    <div class="portrait ring-1 ring-[var(--color-border-strong)] shadow-[0_24px_48px_rgba(0,0,0,0.45)]">
      <img
        src={image}
        alt={`${name}, ${role}`}
        width="640"
        height="640"
        loading="lazy"
        decoding="async"
        onerror="this.replaceWith(Object.assign(document.createElement('div'),{innerHTML:this.dataset.fallback,style:'width:100%;height:100%;'}));"
        data-fallback={`<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 640 640' width='640' height='640' role='img' aria-label='Portrait placeholder'><defs><linearGradient id='spkBg-${slug}' x1='0' y1='0' x2='1' y2='1'><stop offset='0%' stop-color='#1A3E7C'/><stop offset='100%' stop-color='#0A1628'/></linearGradient></defs><rect width='640' height='640' fill='url(#spkBg-${slug})'/><circle cx='320' cy='260' r='95' fill='#5A7BA8' opacity='0.45'/><path d='M150 540 Q150 380 320 380 Q490 380 490 540 Z' fill='#5A7BA8' opacity='0.45'/><text x='320' y='600' text-anchor='middle' font-family='Archivo, Inter, sans-serif' font-weight='700' font-size='28' fill='#E8B547'>${name}</text></svg>`}
      />
    </div>
    <a
      href={`/speakers#${slug}`}
      class="portrait-satellite"
      aria-label={`Read full bio for ${name}`}
      style={accent === 'blue' ? 'background: var(--color-brand-blue); color: #fff;' : ''}
    >→</a>
  </div>

  <div class="eyebrow mt-7">Speaker</div>
  <h3 class="mt-3 text-2xl md:text-3xl font-display font-bold uppercase tracking-tight">{name}</h3>
  <p class="mt-2 text-sm text-[var(--color-ink-muted)] max-w-xs">{role}</p>
  <p class="mt-4 text-[0.95rem] leading-relaxed text-[var(--color-ink)]/85 max-w-sm">{blurb}</p>

  <a href={`/speakers#${slug}`} class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-gold)] hover:text-[var(--color-brand-gold-hi)] transition">
    Read full bio <span aria-hidden="true">→</span>
  </a>
</article>
