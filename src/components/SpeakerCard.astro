---
interface Props {
  name: string;
  role: string;
  slug: string;
  image: string;
  blurb: string;
  accent?: 'gold' | 'blue';
}
const { name, role, slug, image, blurb, accent = 'gold' } = Astro.props;
---

<article class="group relative flex flex-col items-center text-center">
  <div class="relative w-[260px] md:w-[300px] lg:w-[320px]">
    <div class="portrait ring-1 ring-[var(--color-border-strong)] shadow-[0_24px_48px_rgba(0,0,0,0.45)]">
      <img src={image} alt={`${name} — ${role}`} width="640" height="640" loading="lazy" decoding="async" />
    </div>
    <a
      href={`/speakers#${slug}`}
      class="portrait-satellite"
      aria-label={`Read full bio for ${name}`}
      style={accent === 'blue' ? 'background: var(--color-brand-blue); color: #fff;' : ''}
    >→</a>
  </div>

  <div class="eyebrow mt-7">Speaker</div>
  <h3 class="mt-3 text-2xl md:text-3xl font-display font-bold uppercase tracking-tight">{name}</h3>
  <p class="mt-2 text-sm text-[var(--color-ink-muted)] max-w-xs">{role}</p>
  <p class="mt-4 text-[0.95rem] leading-relaxed text-[var(--color-ink)]/85 max-w-sm">{blurb}</p>

  <a href={`/speakers#${slug}`} class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-gold)] hover:text-[var(--color-brand-gold-hi)] transition">
    Read full bio <span aria-hidden="true">→</span>
  </a>
</article>
