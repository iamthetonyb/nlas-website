---
/**
 * NLAS Logo component.
 * -----------------------------------------------------------
 * Two modes:
 *   1. IMAGE MODE (preferred): drop a logo file at
 *        /public/images/logo/nlas-logo.png    (full logo mark + wordmark)
 *        /public/images/logo/nlas-mark.png    (square mark only, for compact/favicon-style use)
 *      PNG or SVG both work. JPG also fine. Rename the extension accordingly in LOGO_IMAGE below.
 *
 *   2. SVG FALLBACK: if those files do NOT exist, we render the stripe-block SVG we had before.
 *      Nothing breaks if the image 404s on a page. The <img> is wrapped in a fallback-aware container.
 *
 * Swap the paths below to match whatever filename you drop in.
 */
interface Props {
  variant?: 'full' | 'mark' | 'compact';
  class?: string;
}
const { variant = 'full', class: className = '' } = Astro.props;

// Point these at your dropped-in logo files. Extension can be .png / .svg / .jpg.
const LOGO_IMAGE_FULL = '/images/logo/nlas-logo.png';
const LOGO_IMAGE_MARK = '/images/logo/nlas-mark.png';
---

{variant === 'mark' && (
  <img
    src={LOGO_IMAGE_MARK}
    alt="NLAS mark"
    class={className}
    width="120"
    height="160"
    loading="eager"
    decoding="async"
    onerror="this.replaceWith(Object.assign(document.createElement('div'),{innerHTML:this.dataset.fallback,className:this.className}));"
    data-fallback={`<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 160' aria-label='NLAS mark' role='img'><defs><linearGradient id='nlasStripe' x1='0' y1='0' x2='1' y2='1'><stop offset='0%' stop-color='#B6C7D9'/><stop offset='45%' stop-color='#3D78C9'/><stop offset='100%' stop-color='#0A3A7A'/></linearGradient><pattern id='diagonals' width='10' height='10' patternUnits='userSpaceOnUse' patternTransform='rotate(45)'><line x1='0' y1='0' x2='0' y2='10' stroke='#0A1628' stroke-width='2'/></pattern></defs><rect x='4' y='4' width='112' height='152' rx='2' fill='url(#nlasStripe)'/><rect x='4' y='4' width='112' height='152' rx='2' fill='url(#diagonals)' opacity='0.5'/></svg>`}
  />
)}

{variant === 'compact' && (
  <div class={`inline-flex items-center gap-3 ${className}`}>
    <img
      src={LOGO_IMAGE_MARK}
      alt=""
      aria-hidden="true"
      width="28"
      height="38"
      class="h-[38px] w-auto object-contain"
      loading="eager"
      decoding="async"
      onerror="this.replaceWith(Object.assign(document.createElement('div'),{innerHTML:this.dataset.fallback,className:'shrink-0'}));"
      data-fallback={`<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 160' width='28' height='38' aria-hidden='true'><defs><linearGradient id='nlasStripeC' x1='0' y1='0' x2='1' y2='1'><stop offset='0%' stop-color='#B6C7D9'/><stop offset='45%' stop-color='#3D78C9'/><stop offset='100%' stop-color='#0A3A7A'/></linearGradient><pattern id='diagonalsC' width='10' height='10' patternUnits='userSpaceOnUse' patternTransform='rotate(45)'><line x1='0' y1='0' x2='0' y2='10' stroke='#0A1628' stroke-width='2'/></pattern></defs><rect x='4' y='4' width='112' height='152' rx='2' fill='url(#nlasStripeC)'/><rect x='4' y='4' width='112' height='152' rx='2' fill='url(#diagonalsC)' opacity='0.5'/></svg>`}
    />
    <span class="font-display font-bold tracking-tight text-[var(--color-ink)] leading-none text-lg">NLAS</span>
  </div>
)}

{variant === 'full' && (
  <div class={`flex items-center gap-5 ${className}`}>
    <img
      src={LOGO_IMAGE_MARK}
      alt=""
      aria-hidden="true"
      width="72"
      height="96"
      class="h-[96px] w-auto object-contain shrink-0"
      loading="eager"
      decoding="async"
      onerror="this.replaceWith(Object.assign(document.createElement('div'),{innerHTML:this.dataset.fallback,className:'shrink-0'}));"
      data-fallback={`<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 160' width='72' height='96' aria-hidden='true'><defs><linearGradient id='nlasStripeF' x1='0' y1='0' x2='1' y2='1'><stop offset='0%' stop-color='#B6C7D9'/><stop offset='45%' stop-color='#3D78C9'/><stop offset='100%' stop-color='#0A3A7A'/></linearGradient><pattern id='diagonalsF' width='10' height='10' patternUnits='userSpaceOnUse' patternTransform='rotate(45)'><line x1='0' y1='0' x2='0' y2='10' stroke='#0A1628' stroke-width='2'/></pattern></defs><rect x='4' y='4' width='112' height='152' rx='2' fill='url(#nlasStripeF)'/><rect x='4' y='4' width='112' height='152' rx='2' fill='url(#diagonalsF)' opacity='0.5'/></svg>`}
    />
    <div class="leading-[0.95]">
      <div class="font-display font-black text-2xl md:text-3xl tracking-tight uppercase text-white">Nevada</div>
      <div class="font-display font-black text-2xl md:text-3xl tracking-tight uppercase text-white">Leadership &amp;</div>
      <div class="font-display font-black text-2xl md:text-3xl tracking-tight uppercase text-white">Accountability</div>
      <div class="script text-3xl md:text-4xl -mt-1">Series</div>
    </div>
  </div>
)}
