---
interface Props {
  variant?: 'full' | 'mark' | 'compact';
  class?: string;
}
const { variant = 'full', class: className = '' } = Astro.props;
---

{variant === 'mark' && (
  <svg viewBox="0 0 120 160" role="img" aria-label="NLAS mark" class={className || 'h-10 w-auto'}>
    <defs>
      <linearGradient id="nlasStripeMark" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#B6C7D9" />
        <stop offset="45%" stop-color="#3D78C9" />
        <stop offset="100%" stop-color="#0A3A7A" />
      </linearGradient>
      <pattern id="diagonalsMark" width="10" height="10" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
        <line x1="0" y1="0" x2="0" y2="10" stroke="#0A1628" stroke-width="2" />
      </pattern>
    </defs>
    <rect x="4" y="4" width="112" height="152" rx="3" fill="url(#nlasStripeMark)" />
    <rect x="4" y="4" width="112" height="152" rx="3" fill="url(#diagonalsMark)" opacity="0.5" />
    <circle cx="92" cy="132" r="10" fill="#E8B547" />
  </svg>
)}

{variant === 'compact' && (
  <div class={`inline-flex items-center gap-3 ${className}`}>
    <svg viewBox="0 0 120 160" aria-hidden="true" class="h-[38px] w-auto shrink-0">
      <defs>
        <linearGradient id="nlasStripeCompact" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#B6C7D9" />
          <stop offset="45%" stop-color="#3D78C9" />
          <stop offset="100%" stop-color="#0A3A7A" />
        </linearGradient>
        <pattern id="diagonalsCompact" width="10" height="10" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
          <line x1="0" y1="0" x2="0" y2="10" stroke="#0A1628" stroke-width="2" />
        </pattern>
      </defs>
      <rect x="4" y="4" width="112" height="152" rx="3" fill="url(#nlasStripeCompact)" />
      <rect x="4" y="4" width="112" height="152" rx="3" fill="url(#diagonalsCompact)" opacity="0.5" />
      <circle cx="92" cy="132" r="10" fill="#E8B547" />
    </svg>
    <span class="font-display font-bold text-[var(--color-ink)] leading-none text-lg">NLAS</span>
  </div>
)}

{variant === 'full' && (
  <div class={`flex items-center gap-5 ${className}`}>
    <svg viewBox="0 0 120 160" aria-hidden="true" class="h-[96px] w-auto shrink-0">
      <defs>
        <linearGradient id="nlasStripeFull" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#B6C7D9" />
          <stop offset="45%" stop-color="#3D78C9" />
          <stop offset="100%" stop-color="#0A3A7A" />
        </linearGradient>
        <pattern id="diagonalsFull" width="10" height="10" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
          <line x1="0" y1="0" x2="0" y2="10" stroke="#0A1628" stroke-width="2" />
        </pattern>
      </defs>
      <rect x="4" y="4" width="112" height="152" rx="3" fill="url(#nlasStripeFull)" />
      <rect x="4" y="4" width="112" height="152" rx="3" fill="url(#diagonalsFull)" opacity="0.5" />
      <circle cx="92" cy="132" r="10" fill="#E8B547" />
    </svg>
    <div class="leading-[0.95]">
      <div class="font-display font-black text-2xl md:text-3xl uppercase text-white">Nevada</div>
      <div class="font-display font-black text-2xl md:text-3xl uppercase text-white">Leadership &amp;</div>
      <div class="font-display font-black text-2xl md:text-3xl uppercase text-white">Accountability</div>
      <div class="script text-3xl md:text-4xl -mt-1">Series</div>
    </div>
  </div>
)}
